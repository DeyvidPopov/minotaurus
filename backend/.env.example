# ───────────────────────── Production (minotaurus.dev) ─────────────────────────
# Same-origin topology: the Next frontend is served at https://minotaurus.dev and
# this API is reverse-proxied at https://minotaurus.dev/api. For a production
# deploy set, at minimum:
#   NODE_ENV=production
#   CORS_ORIGIN=https://minotaurus.dev        (required in prod — startup fails if unset)
#   APP_BASE_URL=https://minotaurus.dev       (absolute links in outbound email)
#   TRUST_PROXY=true                          (so req.ip is the real client, not the proxy)
#   DATABASE_URL=...?sslmode=require          (TLS to the managed Postgres)
#   EMAIL_PROVIDER=resend  +  RESEND_API_KEY  +  MAIL_FROM
# See .env.production.example for a ready-to-copy production template.

# Postgres connection. Database `minotaurus` must exist on the target host.
# In production, append ?sslmode=require (or your provider's TLS param).
DATABASE_URL="postgresql://postgres:admin123!@localhost:5432/minotaurus"

# Runtime mode. Leave unset/"development" locally. Set NODE_ENV=production in
# production — it enables HSTS, the CORS allow-list requirement, and blocks the
# destructive seed/reset scripts.
NODE_ENV=development

PORT=4000
# Required. No fallback — the backend refuses to start if this is missing or
# left at a placeholder value. Use a long, random secret, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Allowed browser origin(s) for CORS, comma-separated. Local dev: the Next dev
# server. Production: the public frontend origin, e.g. https://minotaurus.dev
# (REQUIRED in production — the backend refuses to start with an allow-all policy
# when NODE_ENV=production).
CORS_ORIGIN=http://localhost:3000

# Absolute public base URL of the frontend, used to build links in outbound email
# (verification codes, password reset, validation alerts, digests). Optional in
# dev; SET IT in any real environment or email links render as broken http:///…
# Production: APP_BASE_URL=https://minotaurus.dev
APP_BASE_URL=

# Proxy trust for rate limiting. OFF by default so `req.ip` is the real socket
# peer and a client-supplied X-Forwarded-For cannot forge the rate-limit key.
# Set ONLY when actually behind a known proxy / load balancer:
#   TRUST_PROXY=true          → trust the left-most XFF (one trusted proxy)
#   TRUST_PROXY=1             → trust N proxy hops (integer)
#   TRUST_PROXY=10.0.0.0/8    → trust specific proxy addresses/CIDRs (comma-separated)
TRUST_PROXY=

# Destructive scripts (npm run seed / npm run prisma:reset) refuse to run against
# production (NODE_ENV=production) or a remote/managed database (railway, neon,
# supabase, amazonaws, render, ...). Only localhost / 127.0.0.1 run unguarded.
# Set this to true ONLY to allow an unrecognized-but-local host (e.g. a Docker
# service name). It does NOT bypass the production or remote-host blocks.
ALLOW_DESTRUCTIVE_SEED=false

# AI (Bootstrap Wizard). The proposal layer calls the Anthropic Messages API.
# Without a key the AI endpoints return 503; the rest of the platform is unaffected.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
# Output-token budget for one AI proposal. 8192 fits most ideas; very broad ideas
# may still truncate (handled explicitly as AI_OUTPUT_TRUNCATED). Raise if needed.
AI_MAX_TOKENS=8192
# Output-token budget for one AI Architecture Review. The review schema is bounded
# (~3–5k tokens), so this is headroom, not the primary guard. Defaults to 12000.
AI_REVIEW_MAX_TOKENS=12000

# ───────────────────────── Email (multi-step registration) ─────────────────────────
# Provider: dev | resend | smtp. All optional. With EMAIL_PROVIDER unset/"dev" the
# backend runs with NO email credentials and just logs the verification code
# (masked, dev only) — so local development needs nothing here. Startup is never
# blocked; a misconfigured real provider surfaces 503 EMAIL_NOT_CONFIGURED at send.
#
#   resend → sends real mail via the Resend API (set RESEND_API_KEY). Recommended.
#   smtp   → placeholder fallback (not implemented yet).
#
# To send real verification emails:  EMAIL_PROVIDER=resend  +  RESEND_API_KEY=...
EMAIL_PROVIDER=dev

# Resend (https://resend.com) — required when EMAIL_PROVIDER=resend.
RESEND_API_KEY=

# SMTP — required when EMAIL_PROVIDER=smtp (placeholder; not implemented).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender identity used by the real providers. Use a domain you've verified in Resend.
MAIL_FROM="Minotaurus Team <noreply@minotaurus.dev>"
