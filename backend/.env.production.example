# ════════════════════════════════════════════════════════════════════════════
# PRODUCTION environment template for minotaurus.dev — copy to `.env` on the
# server and fill in the secrets. Same-origin topology: the Next frontend is at
# https://minotaurus.dev and this API is reverse-proxied at https://minotaurus.dev/api.
# NEVER commit the filled-in copy (backend/.env is gitignored).
# ════════════════════════════════════════════════════════════════════════════

NODE_ENV=production

# Managed Postgres over TLS. Append the provider's TLS param (sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@DB_HOST:5432/minotaurus?sslmode=require"

PORT=4000

# Long, random secret — NO fallback (startup fails on a missing/placeholder/short
# value). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Required in production (the backend refuses an allow-all CORS policy). The
# public frontend origin(s), comma-separated.
CORS_ORIGIN=https://minotaurus.dev

# Absolute base for links in outbound email.
APP_BASE_URL=https://minotaurus.dev

# Behind a reverse proxy / load balancer, so req.ip resolves to the real client
# (otherwise every request shares one rate-limit bucket). Use `true` for one
# trusted hop, an integer for N hops, or a comma-separated CIDR allow-list.
TRUST_PROXY=true

# Destructive scripts stay blocked in production regardless (NODE_ENV=production).
ALLOW_DESTRUCTIVE_SEED=false

# ───────────────────────── AI (Bootstrap / Review / Advisor / Docs) ─────────────────────────
# Without ANTHROPIC_API_KEY the AI endpoints return 503; the rest of the platform
# is unaffected. AI generate routes are rate-limited per user (30/hour).
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=8192
AI_REVIEW_MAX_TOKENS=12000

# ───────────────────────── Email (Resend) ─────────────────────────
# Real verification / reset / alert / digest mail. Use a domain verified in Resend.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
MAIL_FROM="Minotaurus Team <noreply@minotaurus.dev>"
