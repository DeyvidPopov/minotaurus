// Prisma schema — Postgres persistence for the Minotaurus MVP.
// Generated as part of Phase 6 (PostgreSQL migration). Mirrors the previous
// JSON DbShape one-to-one so the API contract stays unchanged.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────── Users ──────────────────────────────

enum UserRole {
  ADMIN
  ENGINEER
  ARCHITECT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole @default(ENGINEER)
  createdAt    DateTime @default(now())

  // Set when the account's email was confirmed. Nullable for back-compat: legacy
  // rows (and the single-step /auth/register path) leave it NULL. Accounts created
  // through the multi-step verified flow set it at completion. Login does NOT gate
  // on this yet — it exists so gating can be enabled later without a schema change.
  emailVerifiedAt DateTime?

  // Soft-delete marker for the account-deletion flow. NULL = active account.
  // When the user requests deletion the account is flagged here (and an
  // AccountDeletion row schedules the purge ~30d out); nothing destructive runs
  // until the purge job executes the recorded plan. Cleared on reactivate/undo.
  // Login still SUCCEEDS while set — the response carries deletionPending so the
  // frontend can offer reactivation instead of hard-locking the user out.
  deletedAt DateTime?

  // True only for the single "Deleted User" tombstone sentinel. Surviving
  // authorship from purged accounts is reassigned to it so the history stays
  // honest ("created by Deleted User") instead of misattributing to a real user.
  // The sentinel is excluded from login, member/transfer pickers, and is itself
  // never deletable. See modules/auth/account-deletion.
  isSystem Boolean @default(false)

  accountDeletion   AccountDeletion?   @relation("UserAccountDeletion")

  // Optional "default workspace": the project the user lands in after login.
  // Null = no default (land on the dashboard). SetNull on the FK so deleting the
  // project self-heals the preference instead of leaving a dangling reference.
  defaultProjectId String?
  defaultProject   Project? @relation("UserDefaultProject", fields: [defaultProjectId], references: [id], onDelete: SetNull)

  ownedProjects     Project[]          @relation("ProjectOwner")
  artifacts         Artifact[]
  apiSpecs          ApiSpec[]
  databaseModels    DatabaseModel[]
  diagrams          Diagram[]
  exports           ExportPackage[]
  relationsAuthored ArtifactRelation[]
  versionEvents     VersionEvent[]
  memberships       ProjectMember[]
  ingestionRecords  IngestionRecord[]
  aiSessions        AiSession[]
  emailChange       EmailChange?      @relation("UserEmailChange")
  notificationPreference UserNotificationPreference? @relation("UserNotificationPreference")
}

// ────────────────────────────── Email verification (multi-step registration) ──────────────────────────────
// Pending registration state — NOT a User yet. One row per (normalized) email,
// holding the hashed 6-digit code, expiry/cooldown/attempt counters, and (after
// the code is verified) a hashed short-lived registration token that the final
// "complete" step consumes to create the real User. Never stores the plaintext
// code or token. Expired rows are pruned opportunistically on the next start.
model EmailVerification {
  id        String @id @default(uuid())
  // Normalized (trimmed + lowercased) email. Unique so start/resend upsert one
  // pending record per email.
  email     String @unique
  firstName String
  lastName  String

  // bcrypt hash of the 6-digit numeric code (low entropy → needs the work factor).
  codeHash          String
  expiresAt         DateTime // code expiry (created + 10m)
  attempts          Int      @default(0) // failed verify attempts (cap 5 → resend required)
  resendCount       Int      @default(0) // audit / abuse signal
  resendAvailableAt DateTime // resend cooldown gate (created + 30s)
  verifiedAt        DateTime? // set on successful code verification

  // Short-lived handoff between verify and complete. sha256 hash of a high-entropy
  // random token (fast hash is fine — token is not brute-forceable).
  registrationTokenHash      String?
  registrationTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

// ────────────────────────────── Password reset (forgot-password flow) ──────────────────────────────
// Pending password-reset state for an EXISTING user. One row per (normalized)
// email, holding the hashed 6-digit code, expiry/cooldown/attempt counters, and
// (after the code is verified) a hashed short-lived reset token that the final
// "reset" step consumes to set a new password. Never stores the plaintext code
// or token. A row exists only while a reset is in flight — it is deleted on
// success and pruned opportunistically when expired. Deliberately keyed by email
// (not a User FK) so the table mirrors EmailVerification and the request step can
// stay enumeration-neutral without a join. No firstName/lastName: the greeting
// pulls the recipient's name from the User at send time.
model PasswordReset {
  id    String @id @default(uuid())
  // Normalized (trimmed + lowercased) email. Unique so request/resend upsert one
  // pending record per email.
  email String @unique

  // bcrypt hash of the 6-digit numeric code (low entropy → needs the work factor).
  codeHash          String
  expiresAt         DateTime // code expiry (created + 10m)
  attempts          Int      @default(0) // failed verify attempts (cap 5 → resend required)
  resendCount       Int      @default(0) // audit / abuse signal
  resendAvailableAt DateTime // resend cooldown gate (created + 30s)
  verifiedAt        DateTime? // set on successful code verification

  // Short-lived handoff between verify and reset. sha256 hash of a high-entropy
  // random token (fast hash is fine — token is not brute-forceable).
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

// ────────────────────────────── Email change (verified email-change flow) ──────────────────────────────
// Pending email-change state for an AUTHENTICATED user. One row per user: the
// user requests a change to `newEmail`, a 6-digit code is sent to that NEW
// address, and the swap only happens once the code is verified — proving the
// user owns the new mailbox. Never stores the plaintext code. Deleted on success
// and pruned opportunistically when expired. Mirrors PasswordReset, but keyed by
// userId (the actor is known) and FK'd to User so it cascades on account delete.
model EmailChange {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation("UserEmailChange", fields: [userId], references: [id], onDelete: Cascade)

  // Normalized (trimmed + lowercased) target email — the address being moved to.
  newEmail String

  codeHash          String
  expiresAt         DateTime // code expiry (created + 10m)
  attempts          Int      @default(0) // failed verify attempts (cap 5 → resend required)
  resendCount       Int      @default(0) // audit / abuse signal
  resendAvailableAt DateTime // resend cooldown gate (created + 30s)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

// ────────────────────────────── User notification preferences ──────────────────────────────
// Per-user notification settings (Settings → Notifications). One row per user,
// created lazily on first write — an absent row means "all defaults". Booleans
// only at the MVP: a weekly validation-issue email digest and per-event
// validation alerts. Delivery is NOT implemented yet (no cron/queue) — these
// flags are persisted intent the future sender will read; email always goes to
// the user's verified account address. FK'd to User so it cascades on delete.
model UserNotificationPreference {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation("UserNotificationPreference", fields: [userId], references: [id], onDelete: Cascade)

  emailDigestEnabled      Boolean @default(false)
  validationAlertsEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ────────────────────────────── Account deletion (soft-delete + 30d grace) ──────────────────────────────
// Records a pending account deletion. The request only captures INTENT — the
// per-project plan (transfer vs delete) and a scheduled purge time — and flags
// User.deletedAt; no projects are transferred and no rows are deleted until the
// purge job runs at/after `scheduledFor`. This makes undo trivial (clear the
// flag, drop this row — nothing destructive has happened yet). One row per user.
// FK'd to User with onDelete: Cascade so the eventual purge (a user delete) and
// any reactivation clean it up automatically. Mirrors the EmailChange/PasswordReset
// shape: a hashed single-use token backs the one-click "undo" link in the email.
model AccountDeletion {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation("UserAccountDeletion", fields: [userId], references: [id], onDelete: Cascade)

  // Per-project decisions captured at request time:
  // [{ projectId, action: "TRANSFER" | "DELETE", transferToUserId? }]. Re-validated
  // at purge time (a target can go stale during the 30-day window). Mirrors the
  // lightweight JSON-snapshot pattern used by AiSession/IngestionRecord.
  plan Json @default("[]")

  requestedAt  DateTime @default(now())
  scheduledFor DateTime // requestedAt + grace window (30d); the purge job's due date

  // sha256 of a high-entropy single-use token (fast hash is fine — not brute-forceable),
  // backing the one-click undo link emailed to the user. Never stores the plaintext.
  undoTokenHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledFor])
}

// ────────────────────────────── Projects ──────────────────────────────

model Project {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner            User              @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  artifacts        Artifact[]
  apiSpecs         ApiSpec[]
  databaseModels   DatabaseModel[]
  diagrams         Diagram[]
  validationIssues ValidationIssue[]
  exports          ExportPackage[]
  versionEvents    VersionEvent[]
  members          ProjectMember[]
  ingestionRecords IngestionRecord[]
  aiSessions       AiSession[]
  defaultedByUsers User[]            @relation("UserDefaultProject")

  @@index([ownerId])
}

// ────────────────────────────── Project members ──────────────────────────────

enum ProjectRole {
  OWNER
  ARCHITECT
  DEVELOPER
  VIEWER
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)
  joinedAt  DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// ────────────────────────────── Artifacts ──────────────────────────────

enum ArtifactType {
  DOCUMENTATION
  API_SPEC
  API_ENDPOINT
  SERVICE
  DATABASE_MODEL
  DATABASE_ENTITY
  DIAGRAM
  REQUIREMENT
  SECURITY_POLICY
  ENVIRONMENT
  EXTERNAL_SYSTEM
}

enum ArtifactStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

model Artifact {
  id                   String         @id @default(uuid())
  projectId            String
  title                String
  normalizedTitle      String
  type                 ArtifactType
  status               ArtifactStatus @default(DRAFT)
  description          String         @default("")
  tags                 String[]       @default([])
  gx                   Int            @default(0)
  gy                   Int            @default(0)
  createdById          String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  documentationContent String?

  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy      User               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  relationsOut   ArtifactRelation[] @relation("RelationSource")
  relationsIn    ArtifactRelation[] @relation("RelationTarget")
  apiSpecs       ApiSpec[]
  databaseModels DatabaseModel[]
  diagrams       Diagram[]

  @@unique([projectId, normalizedTitle])
  @@index([projectId])
  @@index([createdById])
}

// ────────────────────────────── Relations ──────────────────────────────

enum RelationType {
  DEPENDS_ON
  DOCUMENTS
  IMPLEMENTS
  USES
  EXPOSES
  BELONGS_TO
  SECURES
  VALIDATES
  COMMUNICATES_WITH
}

model ArtifactRelation {
  id               String       @id @default(uuid())
  sourceArtifactId String
  targetArtifactId String
  relationType     RelationType
  description      String       @default("")
  createdById      String
  createdAt        DateTime     @default(now())

  sourceArtifact Artifact @relation("RelationSource", fields: [sourceArtifactId], references: [id], onDelete: Cascade)
  targetArtifact Artifact @relation("RelationTarget", fields: [targetArtifactId], references: [id], onDelete: Cascade)
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  // A directed edge is unique by (source, target, type): the DB enforces the
  // no-duplicate-edge rule the app already validates (graph SSOT integrity).
  // Directional + type-scoped, so A→B and B→A, and two different relation types
  // between the same pair, all remain distinct allowed edges.
  @@unique([sourceArtifactId, targetArtifactId, relationType])
  @@index([sourceArtifactId])
  @@index([targetArtifactId])
}

// ────────────────────────────── API Specs ──────────────────────────────

model ApiSpec {
  id          String   @id @default(uuid())
  projectId   String
  artifactId  String?
  title       String
  version     String   @default("1.0.0")
  baseUrl     String   @default("")
  description String   @default("")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact  Artifact?     @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  createdBy User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  endpoints ApiEndpoint[]

  @@index([projectId])
  @@index([artifactId])
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model ApiEndpoint {
  id             String     @id @default(uuid())
  apiSpecId      String
  path           String
  method         HttpMethod
  summary        String     @default("")
  requestSchema  String     @default("")
  responseSchema String     @default("")
  requiresAuth   Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  apiSpec ApiSpec @relation(fields: [apiSpecId], references: [id], onDelete: Cascade)

  @@index([apiSpecId])
}

// ────────────────────────────── Database Models ──────────────────────────────

enum DatabaseType {
  PostgreSQL
  MySQL
  MongoDB
  Redis
  SQLite
}

model DatabaseModel {
  id           String       @id @default(uuid())
  projectId    String
  artifactId   String?
  title        String
  databaseType DatabaseType @default(PostgreSQL)
  description  String       @default("")
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact  Artifact?        @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  createdBy User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  entities  DatabaseEntity[]

  @@index([projectId])
  @@index([artifactId])
}

model DatabaseEntity {
  id              String   @id @default(uuid())
  databaseModelId String
  name            String
  description     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  databaseModel DatabaseModel   @relation(fields: [databaseModelId], references: [id], onDelete: Cascade)
  fields        DatabaseField[]
  referencedBy  DatabaseField[] @relation("FieldReferences")

  @@index([databaseModelId])
}

model DatabaseField {
  id                 String  @id @default(uuid())
  entityId           String
  name               String
  type               String  @default("text")
  required           Boolean @default(false)
  isPrimaryKey       Boolean @default(false)
  isForeignKey       Boolean @default(false)
  referencesEntityId String?
  description        String  @default("")

  entity           DatabaseEntity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  referencesEntity DatabaseEntity? @relation("FieldReferences", fields: [referencesEntityId], references: [id], onDelete: SetNull)

  @@index([entityId])
  @@index([referencesEntityId])
}

// ────────────────────────────── Diagrams ──────────────────────────────

enum DiagramType {
  FLOWCHART
  SEQUENCE
  ERD
  CLASS
  STATE
  GANTT
  ARCHITECTURE
}

model Diagram {
  id            String      @id @default(uuid())
  projectId     String
  artifactId    String?
  title         String
  type          DiagramType @default(FLOWCHART)
  mermaidSource String      @default("")
  description   String      @default("")
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact  Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([artifactId])
}

// ────────────────────────────── Validation ──────────────────────────────

enum IssueSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum IssueCategory {
  DOCUMENTATION
  API
  DATABASE
  SECURITY
  ARCHITECTURE
  RELATIONSHIP
  VERSIONING
  DIAGRAM
}

enum IssueStatus {
  OPEN
  RESOLVED
  IGNORED
}

model ValidationIssue {
  id         String        @id @default(uuid())
  projectId  String
  artifactId String
  severity   IssueSeverity
  category   IssueCategory
  message    String
  status     IssueStatus   @default(OPEN)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ────────────────────────────── Export ──────────────────────────────

enum ExportFormat {
  JSON
  MARKDOWN
  PDF
}

model ExportPackage {
  id          String       @id @default(uuid())
  projectId   String
  format      ExportFormat
  sections    String[]     @default([])
  content     Json
  createdById String
  createdAt   DateTime     @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId])
}

// ────────────────────────────── Version events ──────────────────────────────

enum VersionEntityType {
  PROJECT
  ARTIFACT
  RELATION
  DOCUMENTATION
  API_SPEC
  API_ENDPOINT
  DATABASE_MODEL
  DATABASE_ENTITY
  DATABASE_FIELD
  DIAGRAM
  EXPORT
  VALIDATION
}

enum VersionAction {
  CREATED
  UPDATED
  DELETED
  LINKED
  UNLINKED
  VALIDATED
  EXPORTED
}

model VersionEvent {
  id            String            @id @default(uuid())
  projectId     String
  entityType    VersionEntityType
  entityId      String
  action        VersionAction
  title         String
  description   String            @default("")
  triggeredById String
  metadata      Json              @default("{}")
  createdAt     DateTime          @default(now())

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy User    @relation(fields: [triggeredById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([entityId])
  @@index([projectId, createdAt(sort: Desc)])
}

// ────────────────────────────── Ingestion ──────────────────────────────

enum IngestionSourceType {
  MARKDOWN
  OPENAPI_JSON
  MERMAID
  SQL_SCHEMA
}

enum IngestionStatus {
  DRAFT
  PARSED
  CONFIRMED
  FAILED
}

model IngestionRecord {
  id              String              @id @default(uuid())
  projectId       String
  sourceType      IngestionSourceType
  status          IngestionStatus     @default(DRAFT)
  title           String
  sourceName      String              @default("")
  createdRecords  Json                @default("[]")
  parserResult    Json?
  errorMessage    String              @default("")
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
}

// ────────────────────────────── AI (Bootstrap Wizard) ──────────────────────────────
// Lightweight audit metadata for the AI proposal/apply flow. NOT a domain entity —
// it never appears in the knowledge graph. It records what AI proposed and what the
// user confirmed (analogous to IngestionRecord). Applied artifacts / relations /
// diagrams are created through the normal creation paths, never stored here.

enum AiSessionKind {
  BOOTSTRAP
  REVIEW
  ADVISOR
  DOCUMENTATION_DRAFT
}

enum AiSessionStatus {
  PROPOSED
  APPLIED
  DISCARDED
}

model AiSession {
  id                String          @id @default(uuid())
  projectId         String
  kind              AiSessionKind   @default(BOOTSTRAP)
  status            AiSessionStatus @default(PROPOSED)
  idea              String
  model             String          @default("")
  promptTokens      Int             @default(0)
  completionTokens  Int             @default(0)
  proposal          Json?
  artifactsProposed Int             @default(0)
  relationsProposed Int             @default(0)
  diagramsProposed  Int             @default(0)
  artifactsCreated  Int             @default(0)
  relationsCreated  Int             @default(0)
  diagramsCreated   Int             @default(0)
  /// Bootstrap V2 (Phase 1 — Database) audit counts. Like the artifact/relation/diagram
  /// counts above: proposed = what the model emitted, created = what apply persisted.
  databaseModelsProposed   Int        @default(0)
  databaseEntitiesProposed Int        @default(0)
  databaseFieldsProposed   Int        @default(0)
  databaseModelsCreated    Int        @default(0)
  databaseEntitiesCreated  Int        @default(0)
  databaseFieldsCreated    Int        @default(0)
  /// Bootstrap V2 (Phase 2 — API catalog) audit counts. Same proposed/created split.
  apiSpecsProposed     Int        @default(0)
  apiEndpointsProposed Int        @default(0)
  apiSpecsCreated      Int        @default(0)
  apiEndpointsCreated  Int        @default(0)
  /// Set for REVIEW/ADVISOR sessions: stable hash of the AnalysisResult the review/advisory interpreted (for staleness detection).
  analysisHash      String?
  createdById       String
  appliedById       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
}
