# API base URL. Points at the Express backend (see ../../backend).
# Local dev: the backend dev server. Production (minotaurus.dev) uses a
# same-origin reverse proxy under /api — see .env.production (committed):
#   NEXT_PUBLIC_API_BASE_URL=https://minotaurus.dev/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
