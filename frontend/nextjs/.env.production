# Production environment for the Next frontend (minotaurus.dev).
# Loaded automatically by `next build` / `next start` when NODE_ENV=production;
# local dev uses .env.local / .env.development instead, so this never affects dev.
# NEXT_PUBLIC_* values are inlined into the client bundle — keep them non-secret.
#
# Same-origin topology: the Express API is reverse-proxied under /api on the same
# host as the frontend, so this is an absolute URL on the production origin.
NEXT_PUBLIC_API_BASE_URL=https://minotaurus.dev/api
